# ============================================================================
# I-Dash Production Environment Configuration
# ============================================================================
# Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to version control
# ============================================================================

# Application Configuration
# ============================================================================
APP_NAME=I-Dash Analytics
APP_VERSION=1.0.0
DEBUG=false

# Server Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/dbname

DB_USER=idash
# IMPORTANT: Generate a strong password with: openssl rand -base64 32
DB_PASSWORD=your-secure-db-password-here
DB_NAME=idash
DB_PORT=5432

# For Docker Compose, use: postgresql+asyncpg://idash:password@postgres:5432/idash
# For external PostgreSQL: postgresql+asyncpg://user:pass@db.example.com:5432/idash
DATABASE_URL=postgresql+asyncpg://idash:your-secure-db-password-here@postgres:5432/idash

# ============================================================================
# Redis Configuration (Caching & Sessions)
# ============================================================================

REDIS_PASSWORD=your-secure-redis-password-here
REDIS_PORT=6379
# For Docker Compose: redis://:password@redis:6379/0
# For external Redis: redis://:password@redis.example.com:6379/0
REDIS_URL=redis://:your-secure-redis-password-here@redis:6379/0

# ============================================================================
# Security Configuration
# ============================================================================
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - Comma-separated list of allowed origins
# Production example: https://idash.example.com,https://app.idash.example.com
CORS_ORIGINS=https://idash.example.com,https://app.idash.example.com

# ============================================================================
# HubSpot Integration
# ============================================================================
# Get from: https://app.hubspot.com/l/integrations/connect-app
HUBSPOT_API_KEY=

# ============================================================================
# Meta (Facebook) Integration
# ============================================================================
# Get from: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ============================================================================
# Google Ads Integration
# ============================================================================
# Setup guide: https://developers.google.com/google-ads/api/docs/oauth/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Format: 123-456-7890 (with hyphens)
GOOGLE_ADS_CUSTOMER_ID=

# ============================================================================
# Google Sheets Integration
# ============================================================================
# Path to service account JSON file
# Generate from: https://console.cloud.google.com/
GOOGLE_SHEETS_CREDENTIALS_FILE=/app/credentials/google-service-account.json

# ============================================================================
# Anthropic (Claude) Integration
# ============================================================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ============================================================================
# Data Refresh Configuration
# ============================================================================
# Interval in hours between automatic data refresh cycles
DATA_REFRESH_INTERVAL_HOURS=4

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@idash.example.com
SMTP_TLS=true

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=

# ============================================================================
# Frontend Configuration
# ============================================================================
# API URL visible to the browser
# Usually the same as your domain since Nginx reverses proxy
VITE_API_URL=https://idash.example.com/api

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_REALTIME=true

# ============================================================================
# Docker Compose Specific
# ============================================================================
COMPOSE_PROJECT_NAME=idash
COMPOSE_FILE=docker/docker-compose.yml

# ============================================================================
# Optional: Backup Configuration
# ============================================================================
# S3 bucket for automated backups
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================================================
# Notes for Production Deployment
# ============================================================================
# 1. Generate strong passwords:
#    - DB_PASSWORD: openssl rand -base64 32
#    - REDIS_PASSWORD: openssl rand -base64 32
#    - SECRET_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Set CORS_ORIGINS to your actual domain(s)
#
# 3. Update DATABASE_URL and REDIS_URL if using external services
#
# 4. Configure all API keys for integrations
#
# 5. Set DEBUG=false in production
#
# 6. For HTTPS/SSL:
#    - Use Let's Encrypt: https://letsencrypt.org/
#    - Update nginx-proxy.conf with your domain
#    - Mount certificates in docker-compose.yml
#
# 7. Set up monitoring and alerts
#
# 8. Regular backups: Enable S3 backup or use backup-db.sh script
#
# 9. Monitor logs: docker-compose logs -f backend
#
# 10. Security checklist:
#     - Never commit .env.production
#     - Rotate secrets periodically
#     - Enable firewall (ufw)
#     - Use fail2ban for brute-force protection
#     - Keep Docker images updated
#     - Regular security audits
